<!DOCTYPE html>
<html lang="pl">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">

        <title>{% block title %}B2B Ordering System{% endblock %}</title>

        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">

        <link rel="stylesheet" href="{{ asset('assets/css/bootstrap.min.css') }}">

        {% block stylesheets %}
        {% endblock %}
    </head>

    <body>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
            <div class="container">
                <a class="navbar-brand" href="{{ path('app_home') }}">
                    B2B Ordering System
                </a>

                <div class="ms-auto d-flex align-items-center gap-2">
                    {% if app.user %}
                        <span class="navbar-text">
                            {{ app.user.userIdentifier }}
                        </span>

                        {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_EMPLOYEE') %}
                            {% if app.request.attributes.get('_route') == 'app_admin' %}
                                <a class="btn btn-outline-light btn-sm" href="{{ path('app_home') }}">
                                    Home
                                </a>
                            {% else %}
                                <a class="btn btn-outline-light btn-sm" href="{{ path('app_admin') }}">
                                    Admin
                                </a>
                            {% endif %}
                        {% endif %}

                        <a class="btn btn-outline-light btn-sm" href="{{ path('app_logout') }}">
                            Wyloguj
                        </a>
                    {% else %}
                        <a class="btn btn-outline-light btn-sm" href="{{ path('app_login') }}">
                            Zaloguj
                        </a>
                    {% endif %}
                </div>
            </div>
        </nav>

        <main class="container">
            {% block body %}{% endblock %}
        </main>

        <script src="{{ asset('assets/js/bootstrap.bundle.min.js') }}"></script>

        {% block javascripts %}
        {% endblock %}
    </body>
</html>